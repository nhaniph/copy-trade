ANTHROPIC_API_KEY=your_anthropic_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Telegram bot token and your chat ID
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Full URL of the Discord channel to watch (copy from your browser)
# Example: https://discord.com/channels/123456789/987654321
DISCORD_CHANNEL_URL=https://discord.com/channels/SERVER_ID/CHANNEL_ID

# Comma-separated display names to watch (as they appear in Discord)
WATCHED_NAMES=tr16

# How often to check for new messages (seconds)
POLL_INTERVAL_SECONDS=15
